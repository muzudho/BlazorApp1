				Console.WriteLine($@"[{DateTime.Now}][ＯnAfterRenderAsync(firstRender = {firstRender}) > End][CSR:{this.RendererInfo.IsInteractive}]
----------------------------------------
■【さ】終
----------------------------------------
");
			}
			else
			{
				Console.WriteLine($@"[{DateTime.Now}][ＯnAfterRenderAsync(firstRender = {firstRender}) > End][CSR:{this.RendererInfo.IsInteractive}]　✖【さ】終（{count}回目）　終了。");
			}
		}
		else
		{
			if (count == 2)
			{
				Console.WriteLine($@"[{DateTime.Now}][ＯnAfterRenderAsync(firstRender = {firstRender}) > End][CSR:{this.RendererInfo.IsInteractive}]
----------------------------------------
■【す】終
----------------------------------------
");
			}
			else if (count == 3)
