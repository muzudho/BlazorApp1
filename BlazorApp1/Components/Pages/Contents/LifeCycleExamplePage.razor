	}


	/// <summary>
	/// 画面を開いたときに最初に呼び出されるメソッドだぜ（＾～＾）
	/// </summary>
	protected override void OnInitialized()
	{
		if (!this.RendererInfo.IsInteractive)
		{
			// サーバーサイドで実行されるので、クライアントのコンソールには出ないぜ（＾～＾）
			this.LoggingSvc.Others.LogInformation($@"[{DateTime.Now}][ＯnInitialized() > Begin][CSR:{this.RendererInfo.IsInteractive}]
----------------------------------------
🌟【あ】始
----------------------------------------
");
		}
		else
		{
			Console.WriteLine($@"[{DateTime.Now}][ＯnInitialized() > Begin][CSR:{this.RendererInfo.IsInteractive}]
----------------------------------------
🌟【か】始
----------------------------------------
");
		}
		base.OnInitialized();

		Console.WriteLine($@"[{DateTime.Now}][ＯnInitialized()][CSR:{this.RendererInfo.IsInteractive}]　このメソッドは同期なんで、邪魔が入らない（＾～＾）　ここで時間がかかると、他の処理も全部止まるぜ（＾～＾） 画面は前の画面のまま更新されないぜ（＾～＾）");
		StudyHelper.BadSleep(seconds: 10);	// ここで何か時間のかかる処理をしてみる。

		if (!this.RendererInfo.IsInteractive)
		{
			// サーバーサイドで実行されるので、クライアントのコンソールには出ないぜ（＾～＾）
			this.LoggingSvc.Others.LogInformation($@"[{DateTime.Now}][ＯnInitialized() > End][CSR:{this.RendererInfo.IsInteractive}]
----------------------------------------
【あ】終
----------------------------------------
");
		}
		else
		{
			Console.WriteLine($@"[{DateTime.Now}][ＯnInitialized() > End][CSR:{this.RendererInfo.IsInteractive}]
----------------------------------------
【か】終
----------------------------------------
");
		}
		this.Message1 = $"ＯnInitialized() が呼び出されました。({DateTime.Now})";
	}


