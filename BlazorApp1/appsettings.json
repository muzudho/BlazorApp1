{
    "AppName": "BlazorApp1",

    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "LoggingExtensions": {
        "Serilog": {
            "MinimumLevel": {
                "Default": "Debug",
                "Override": {
                    "Microsoft": "Warning",
                    "System": "Warning",
                    "KifuwaraperyCS": "Information"
                }
            },
            "WriteTo": [
                {
                    "Name": "Console"
                },
                {
                    "Name": "File",
                    "Args": {
                        "path": "Logs/App-.log",
                        "rollingInterval": "Day"
                    }
                },
                {
                    "Name": "Logger",
                    "Args": {
                        "configureLogger": {
                            "Filter": [
                                {
                                    "Name": "ByIncludingOnly",
                                    "Args": {
                                        "expression": "SourceContext = 'MuzOthersLogger'"
                                    }
                                }
                            ],
                            "WriteTo": [
                                {
                                    "Name": "File",
                                    "Args": {
                                        "path": "Logs/Others-.log",
                                        "rollingInterval": "Day"
                                    }
                                }
                            ]
                        }
                    }
                },
                {
                    "Name": "Logger",
                    "Args": {
                        "configureLogger": {
                            "Filter": [
                                {
                                    "Name": "ByIncludingOnly",
                                    "Args": {
                                        "expression": "SourceContext = 'MuzVerboseLogger'"
                                    }
                                }
                            ],
                            "WriteTo": [
                                {
                                    "Name": "File",
                                    "Args": {
                                        "path": "Logs/Verbose-.log",
                                        "rollingInterval": "Day"
                                    }
                                }
                            ]
                        }
                    }
                }
            ],
            "Enrich": [ "FromLogContext" ],
            "Properties": {
                "Application": "KifuwaraperyCS"
            }
        }
    },

    "AllowedHosts": "*"
}
