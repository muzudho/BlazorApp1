{
    "AppName": "BlazorApp1",

    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "LoggingExtensions": {
        "Serilog": {
            "MinimumLevel": {
                "Default": "Information",
                "Override": {
                    "Microsoft": "Warning",
                    "System": "Warning",
                    "KifuwaraperyCS": "Information"
                }
            },
            "WriteTo": [
                {
                    "Name": "Console"
                },
                {
                    "Name": "File",
                    "Args": {
                        "path": "Logs/App-.log",
                        "rollingInterval": "Day"
                    }
                }
            ],
            "Enrich": [ "FromLogContext" ],
            "Properties": {
                "Application": "KifuwaraperyCS"
            }
        }
    },

    "AllowedHosts": "*"
}
