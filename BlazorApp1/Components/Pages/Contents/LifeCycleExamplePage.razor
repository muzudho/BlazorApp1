			Console.WriteLine($@"[{DateTime.Now}][ＯnInitializedAsync() > Begin][CSR:{this.RendererInfo.IsInteractive}]
----------------------------------------
🌟【き】始
----------------------------------------
");
		}
		await base.OnInitializedAsync();

		// Console.WriteLine($"[{DateTime.Now}][ＯnInitializedAsync()][CSR:{this.RendererInfo.IsInteractive}]　OnInitialized() で止まってても、 OnAfterRender(), OnAfterRenderAsync() は始まるぜ（＾～＾）");
		// await StudyHelper.TimerAsync(   // ここで何か時間のかかる処理をしてみる。
		// 	seconds: 3,
		// 	onTicked: async () =>
		// 	{
		// 		Console.WriteLine($"[{DateTime.Now}][ＯnInitializedAsync()][CSR:{this.RendererInfo.IsInteractive}]　Tick");
		// 	});

		if (!this.RendererInfo.IsInteractive)
		{
			// サーバーサイドで実行されるので、クライアントのコンソールには出ないぜ（＾～＾）
			this.LoggingSvc.Others.LogInformation($@"[{DateTime.Now}][ＯnInitializedAsync() > End][CSR:{this.RendererInfo.IsInteractive}]
----------------------------------------
■【い】終
----------------------------------------
");
		}
		else
		{
			Console.WriteLine($@"[{DateTime.Now}][ＯnInitializedAsync() > End][CSR:{this.RendererInfo.IsInteractive}]
----------------------------------------
■【き】終
----------------------------------------
");
		}
		this.Message2 = $"ＯnInitializedAsync() が呼び出されました。({DateTime.Now})";
	}


