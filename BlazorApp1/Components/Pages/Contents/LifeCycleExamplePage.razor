	/// <summary>
	///		<pre>
	///	- `App.razor` の `<Routes @rendermode="InteractiveServer" />` がないと、このメソッドは呼び出されないぜ（＾～＾）
	/// - `OnInitialized()` 、または `OnParametersSetAsync()` が動いているときはそれが、終わってから呼び出されるメソッドだぜ（＾～＾）
	/// - `OnParametersSetAsync()` でブロック時間が長いとき、そのブロッが解除されたタイミングで、余分にこの `OnAfterRender*(firstRender = false)` が呼び出されるケースがあるぜ（＾～＾）
	///		</pre>
	/// </summary>
	/// <param name="firstRender"></param>
	protected override void OnAfterRender(bool firstRender)
	{
		this.NumberOfAfterRender++;
		var count = this.NumberOfAfterRender;

		if (firstRender)
		{
			if(count == 1)
			{
				Console.WriteLine($@"[{DateTime.Now}][ＯnAfterRender(firstRender = {firstRender}) > Begin][CSR:{this.RendererInfo.IsInteractive}]
----------------------------------------
🌟【こ】始
----------------------------------------
");
			}
			else
			{
				Console.WriteLine($@"[{DateTime.Now}][ＯnAfterRender(firstRender = {firstRender}) > Begin][CSR:{this.RendererInfo.IsInteractive}]　✖【こ】始（{count}回目）　開始。");
			}
		}
		else
		{
			if (count == 2)
			{
				Console.WriteLine($@"[{DateTime.Now}][ＯnAfterRender(firstRender = {firstRender}) > Begin][CSR:{this.RendererInfo.IsInteractive}]
----------------------------------------
🌟【し】始
----------------------------------------
");
			}
			else if (count == 3)
			{
				Console.WriteLine($@"[{DateTime.Now}][ＯnAfterRender(firstRender = {firstRender}) > Begin][CSR:{this.RendererInfo.IsInteractive}]
----------------------------------------
🌟【せ】始
----------------------------------------
");
			}
			else
			{
				Console.WriteLine($@"[{DateTime.Now}][ＯnAfterRender(firstRender = {firstRender}) > Begin][CSR:{this.RendererInfo.IsInteractive}]
----------------------------------------
✖【しせ】始（{count}回目）
----------------------------------------
");
			}
		}

		base.OnAfterRender(firstRender);

		Console.WriteLine($"[{DateTime.Now}][ＯnAfterRender(firstRender = {firstRender})][CSR:{this.RendererInfo.IsInteractive}]　このメソッドは同期なんで邪魔が入らない（＾～＾）　ここで時間がかかると、他の処理も全部止まるぜ（＾～＾）");
		StudyHelper.BadSleep(seconds: 10);  // ここで何か時間のかかる処理をしてみる。

		if (firstRender)
		{
			if (count == 1)
			{
				Console.WriteLine($@"[{DateTime.Now}][ＯnAfterRender(firstRender = {firstRender}) > End][CSR:{this.RendererInfo.IsInteractive}]
----------------------------------------
■【こ】終
----------------------------------------
");
			}
			else
			{
				Console.WriteLine($@"[{DateTime.Now}][ＯnAfterRender(firstRender = {firstRender}) > End][CSR:{this.RendererInfo.IsInteractive}]　✖【こ】終（{count}回目）　終了。");
			}
		}
		else
		{
			if (count == 2)
			{
				Console.WriteLine($@"[{DateTime.Now}][ＯnAfterRender(firstRender = {firstRender}) > End][CSR:{this.RendererInfo.IsInteractive}]
----------------------------------------
■【し】終
----------------------------------------
");
			}
			else if (count == 3)
			{
				Console.WriteLine($@"[{DateTime.Now}][ＯnAfterRender(firstRender = {firstRender}) > End][CSR:{this.RendererInfo.IsInteractive}]
----------------------------------------
■【せ】終
----------------------------------------
");
			}
			else
			{
				Console.WriteLine($@"[{DateTime.Now}][ＯnAfterRender(firstRender = {firstRender}) > End][CSR:{this.RendererInfo.IsInteractive}]
----------------------------------------
✖【しせ】終（{count}回目）　終了。
----------------------------------------
");
			}
		}

		this.Message5 = $"ＯnAfterRender(firstRender) が呼び出されました。({DateTime.Now})";
	}


	/// <summary>
